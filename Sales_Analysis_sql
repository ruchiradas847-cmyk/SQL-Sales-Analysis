CREATE DATABASE sales_project;
USE sales_project;

CREATE TABLE sales_data (
    order_id INT,
    customer_name VARCHAR(50),
    product VARCHAR(50),
    category VARCHAR(50),
    quantity INT,
    price INT,
    order_date DATE,
    city VARCHAR(50)
);
