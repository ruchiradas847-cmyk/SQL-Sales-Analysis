-- 1. View all records from sales_data table
SELECT * FROM sales_data;

-- 2. Filter: Get all records from Kolkata
SELECT * FROM sales_data
WHERE city = 'Kolkata';

-- 3. Total sales per category
SELECT category, SUM(quantity * price) AS total_sales
FROM sales_data
GROUP BY category;

-- 4. Top 3 highest sales orders
SELECT *, (quantity * price) AS total_amount
FROM sales_data
ORDER BY total_amount DESC
LIMIT 3;

-- 5. Count number of orders per city
SELECT city, COUNT(*) AS total_orders
FROM sales_data
GROUP BY city;

-- 6. Average price per category
SELECT category, AVG(price) AS avg_price
FROM sales_data
GROUP BY category;

-- 7. Total spending by each customer 
SELECT customer_name, SUM(quantity * price) AS total_spent
FROM sales_data
GROUP BY customer_name
ORDER BY total_spent DESC;